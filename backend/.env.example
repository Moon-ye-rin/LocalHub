DATABASE_URL=sqlite:///./localhub.db
CORS_ORIGINS=http://localhost:5173,https://YOUR_NETLIFY_SITE.netlify.app
USE_OPENAI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
SEED_DATA=true
SEED_LOCATIONS=true
DATA_DIR=app/data
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880
FRONTEND_PUBLIC_URL=http://localhost:5173

# OpenStreetMap 도로망 기반 A* 길찾기
OVERPASS_URL=https://overpass-api.de/api/interpreter
ROUTE_TIMEOUT_SECONDS=45
ROUTE_MAX_DISTANCE_KM=45
ROUTE_MAX_SNAP_METERS=1500
ROUTE_MAX_GRAPH_NODES=120000